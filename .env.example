# Voice Memory Environment Configuration

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Model Configuration
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_WHISPER_LARGE_MODEL=whisper-1
OPENAI_GPT_MODEL=gpt-4-turbo-preview

# Rate Limiting Configuration
OPENAI_WHISPER_RATE_LIMIT=50
OPENAI_WHISPER_MAX_CONCURRENT=5
OPENAI_GPT_RATE_LIMIT=200
OPENAI_GPT_MAX_CONCURRENT=10

# Retry Configuration
OPENAI_RETRY_ATTEMPTS=3
OPENAI_RETRY_BASE_DELAY=1000
OPENAI_RETRY_MAX_DELAY=10000

# Processing Configuration
PROCESSING_TIMEOUT_MINUTES=15
USE_DATABASE_RATE_LIMITING=true

# Audio Processing Configuration
ENABLE_AUDIO_OPTIMIZATION=true
MAX_AUDIO_FILE_SIZE=25000000
TARGET_AUDIO_SAMPLE_RATE=16000
TARGET_AUDIO_BITRATE=64000
ENABLE_AUDIO_CHUNKING=true
MAX_CHUNK_SIZE_SECONDS=300
CHUNK_OVERLAP_SECONDS=10

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_COST_TRACKING=true
METRICS_RETENTION_DAYS=30

# Caching Configuration
ENABLE_TRANSCRIPTION_CACHE=true
CACHE_DURATION_HOURS=24
MAX_CACHE_SIZE=100

# Video Processing (Future)
ENABLE_VIDEO_PROCESSING=false
FFMPEG_PATH=/usr/bin/ffmpeg

# Admin Configuration
ADMIN_API_KEY=your_admin_api_key

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=
VERCEL_URL=

# Development/Production Settings
NODE_ENV=development